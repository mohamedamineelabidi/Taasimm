# TaaSim demo environment template
# Copy to .env and change values for non-demo deployments.
# The defaults below are intentionally weak and only acceptable for local demos.

# Shared MinIO + S3 Sink credentials
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# API JWT signing secret
JWT_SECRET=taasim-secret-key-change-in-production

# Grafana admin login
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Optional API override
# TRIP_REQUEST_TOPIC=raw.trips

# Optional producer throughput tuning (lower values improve local stability)
# GPS_PRODUCER_SPEED=8
# GPS_FLEET_SIZE=600
# TRIP_PRODUCER_SPEED=12

# Optional verifier lag thresholds (override defaults in scripts/verify-flink-jobs.ps1)
# MAX_LAG_RAW_GPS=2000
# MAX_LAG_PROCESSED_GPS_DEMAND=2500
# MAX_LAG_PROCESSED_GPS_MATCHER=2500
# MAX_LAG_RAW_TRIPS=500
